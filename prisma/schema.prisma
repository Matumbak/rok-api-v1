generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Kingdom stat cards shown above the requirements on the Migration page.
/// `value` is free-text (e.g. "84.2B", "1,240", "12.6T") so the admin can
/// format it any way they like. `iconKey` is a lucide-react icon name.
model KingdomStat {
  id        String   @id @default(cuid())
  label     String
  value     String
  iconKey   String   @default("Trophy")
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("kingdom_stats")
}

/// Migration requirements shown on the landing's Migration page.
/// `iconKey` references a lucide-react icon name on the frontend.
model MigrationRequirement {
  id          String   @id @default(cuid())
  title       String
  description String
  iconKey     String   @default("Crown")
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("migration_requirements")
}

/// YouTube media items shown on the landing's Media page.
/// `title` is auto-fetched from YouTube oEmbed when the URL is saved
/// (admin can override it manually).
model MediaItem {
  id          String   @id @default(cuid())
  url         String   @unique
  title       String
  thumbnail   String
  videoId     String
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("media_items")
}

/// A single DKP scan upload. Columns metadata + the rows it produced.
/// Only one scan is "current" at a time — uploads atomically replace
/// the entire collection.
model DkpScan {
  id         String   @id @default(cuid())
  filename   String
  /// Array of { key, label, type, order, sortable, native }.
  /// Postgres JSONB — efficient indexing + native JSON ops.
  columns    Json
  rowCount   Int      @default(0)
  uploadedAt DateTime @default(now())

  rows       DkpRow[]

  @@map("dkp_scans")
}

/// A single governor row within a scan. Native fields (rank, governorId,
/// nickname, alliance) are stored as columns for fast index-backed search
/// and filtering. Every other field — including arbitrary ones we've never
/// seen before — lives in `data` keyed by the original column label.
model DkpRow {
  id          String   @id @default(cuid())
  scanId      String
  scan        DkpScan  @relation(fields: [scanId], references: [id], onDelete: Cascade)

  rank        Int
  governorId  String
  nickname    String
  alliance    String

  /// JSONB { [columnLabel]: rawValue }. Numbers stored as strings to survive
  /// BigInt; sorting on these fields uses (data->>'key')::numeric in raw SQL.
  data        Json

  @@index([scanId, rank])
  @@index([scanId, nickname])
  @@index([scanId, governorId])
  @@index([scanId, alliance])
  @@map("dkp_rows")
}

/// A migration application submitted by a prospective governor through the
/// landing's /migration/apply form. Screenshots are stored in Vercel Blob —
/// `screenshots` holds an array of { url, label, size, contentType }. Blobs
/// are auto-cleaned when an admin transitions the status (archived → now,
/// rejected → +30d, approved → +90d). Pending applications keep their blobs.
model MigrationApplication {
  id              String    @id @default(cuid())

  // Identity (always manual, required).
  governorId      String
  nickname        String
  currentKingdom  String
  currentAlliance String?
  discordHandle   String

  // Stats — free text so we don't reject odd formats ("84M" / "84,200,000").
  // OCR auto-fills these on submit; admin can correct any of them.
  power           String
  killPoints      String
  vipLevel        String

  // Power breakdown — sourced from "Подробнее → Войска → Мощь" tab. Helps
  // admin spot lopsided builds (e.g. heavy builder vs combat-oriented).
  constructionPower String?
  technologyPower   String?
  troopPower        String?
  commanderPower    String?
  /// Historical maximum power achieved by the governor.
  maxPower          String?

  // Combat statistics from the same details panel.
  wins              String?
  losses            String?
  /// Ark of Osiris wins — proxy for KvK / coordinated PvP experience.
  arkOsirisWins     String?
  /// Current KvK valor points (Очки доблести).
  valorPoints       String?
  /// Lifetime maximum valor points (Макс. кол-во очк. доблести).
  maxValorPoints    String?

  t1Kills           String?
  t2Kills           String?
  t3Kills           String?
  t4Kills           String?
  t5Kills           String?
  deaths            String?
  healed            String?
  resourcesGathered String?

  // Resources — the four storables shown on the in-game resources tab.
  // Free-text strings preserve the user's chosen format ("3.6B" /
  // "3,600,000,000"); the *N columns hold the parsed Float for sorting.
  food              String?
  wood              String?
  stone             String?
  gold              String?

  // Speedups — five canonical RoK categories. Stored as Int minutes,
  // matching how the in-game "Всего" / "Total" duration is summed.
  // `speedupsMinutes` is the grand total (sum of the five) for sortability.
  speedupsMinutes              Int?
  speedupsUniversalMinutes     Int?
  speedupsConstructionMinutes  Int?
  speedupsResearchMinutes      Int?
  speedupsTrainingMinutes      Int?
  speedupsHealingMinutes       Int?
  /// Per-KvK stats — populated from a DKP-scan row uploaded with the
  /// migration form. Distinct from the account-wide power/killPoints/
  /// t4Kills/etc. above: a DKP scan reflects what was achieved DURING
  /// the last KvK only. We keep them on separate columns so admin can
  /// compare "what they did last cycle" against "what they bring now".
  prevKvkKillPoints    String?
  prevKvkT4Kills       String?
  prevKvkT5Kills       String?
  prevKvkDeaths        String?
  prevKvkKillPointsN   Float?
  prevKvkT4KillsN      Float?
  prevKvkT5KillsN      Float?
  prevKvkDeathsN       Float?

  /// Position within the applicant's kingdom-of-origin DKP scan.
  /// Captured from the matched DKP-scan row when the applicant uploads
  /// their KvK export at submission. Lets scoring reward "you ranked
  /// top-50 in a 2400-player scan" independently of absolute output —
  /// useful for applicants from small or weak-match kingdoms whose
  /// absolute numbers look modest but who clearly carried their cycle.
  prevKvkRank             Int?
  /// Total ACTIVE fighters in that DKP scan (filtered by dkp > 0 OR
  /// t5 > 100K). Denominator for the rank percentile.
  prevKvkScanActiveCount  Int?

  /// What OCR / DKP-lookup auto-filled at submit time, per watched
  /// field. Used to compute drift flags in admin: if the applicant's
  /// final value diverges by >5% from what was auto-detected, an
  /// amber "auto-edited" pill is shown next to the value with a
  /// popover comparing both. Stored as normalized numbers (minutes
  /// for speedups, raw integers for everything else). Shape:
  ///   { power: 84000000, killPoints: 152000000,
  ///     speedupsConstruction: 91460, ... }
  /// Only the watched-field set is allowed; other keys are ignored.
  ocrAutofill          Json?

  /// Object holding any extra speedup categories the parser didn't recognize
  /// (event speedups, KvK speedups, etc.). Free-form by design.
  speedupsBreakdown Json?

  // Normalized numeric copies for sorting / filtering. Float64 holds RoK
  // values comfortably (max ~10^13). Computed at write time from the
  // matching string field via lib/parse-rok-number.ts.
  powerN            Float?
  killPointsN       Float?
  t1KillsN          Float?
  t2KillsN          Float?
  t3KillsN          Float?
  t4KillsN          Float?
  t5KillsN          Float?
  deathsN           Float?
  healedN           Float?
  resourcesGatheredN Float?
  foodN             Float?
  woodN             Float?
  stoneN            Float?
  goldN             Float?
  previousKvkDkpN   Float?
  constructionPowerN Float?
  technologyPowerN  Float?
  troopPowerN       Float?
  commanderPowerN   Float?
  maxPowerN         Float?
  winsN             Float?
  lossesN           Float?
  arkOsirisWinsN    Float?
  valorPointsN      Float?
  maxValorPointsN   Float?

  /// Raw OCR text concatenated across all uploaded screenshots — kept so
  /// admin can re-parse / debug if a field looks wrong.
  ocrRawText        String?

  /// Account birth date — derived from the starter Scout commander's
  /// "Recruit Date" via OCR (the Scout is auto-given to every player
  /// within ~2 minutes of account creation, so its hire date == the
  /// account creation date). Null if no Scout screenshot was provided
  /// or the screen failed verification.
  accountBornAt     DateTime?
  /// True iff a submitted commander screenshot was successfully verified
  /// as the Scout. Distinct from `accountBornAt != null` because we want
  /// to surface "applicant uploaded the wrong commander" in admin even
  /// if a date couldn't be parsed off the verified screen.
  scoutVerified     Boolean   @default(false)

  /// Self-declared spending bracket. One of: "f2p" | "low" | "mid" |
  /// "high" | "whale" | "kraken". Required on every new submission;
  /// nullable in DB only because Prisma needs a column-level default
  /// or NULLability to add it without a write-time backfill.
  spendingTier      String?

  /// Which scoring profile the formula uses for this applicant. Drives
  /// stage-aware pivots — Lost Kingdom (KvK 1-4) numbers are ~10× lower
  /// than Season of Conquest. Null = use the server default
  /// (currently `lost-kingdom` for kingdom 4028 in KvK1).
  scoringProfile    String?

  /// Cached overall score (0..100) recomputed on every write. Null only
  /// on records that pre-date the scoring engine (legacy seed data).
  overallScore      Float?
  /// Auto-derived tag slugs (e.g. ["veteran", "active-fighter",
  /// "f2p-hero", "top-5pct"]). Recomputed on every write.
  tags              Json?
  /// Officer-added free-form tag slugs. Lives separately from auto
  /// `tags` so an admin's curated list survives every recompute.
  manualTags        Json?

  /// Number of marches the applicant can field at once. Manual input —
  /// officers eyeball commanders / equipment from the screenshots.
  marches           Int?
  /// Object: { legendary: "5", epic: "12", ... } — admin can fill from screens.
  equipmentSummary  Json?
  previousKvkDkp    String?

  // Workflow / preferences.
  activityHours   String?
  timezone        String?
  hasScrolls      Boolean   @default(false)
  reason          String?

  /// Array of { url, pathname, category, label, size, contentType }.
  screenshots     Json      @default("[]")

  status          String    @default("pending")
  adminNotes      String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  reviewedAt      DateTime?
  /// Set when status transitions away from `pending`. Cleanup job nukes
  /// the screenshots once this is in the past; the row itself stays so
  /// the parsed numeric data remains queryable.
  blobCleanupAt   DateTime?

  @@index([status, createdAt])
  @@index([governorId])
  @@map("migration_applications")
}

/// Auto-learning cohort calibration. Each row holds the empirically-blended
/// p50/p80/p95/p99 anchors for one (stage × spending_tier) cohort, derived
/// from approved applications matching that cohort. computeScore reads
/// from this table when present and falls back to hardcoded COHORTS otherwise.
///
/// Anchors = Bayesian blend of hardcoded prior + observed:
///   effective_p99 = (PRIOR_WEIGHT × hardcoded + n × empirical) / (PRIOR_WEIGHT + n)
///
/// Recalibration triggers: (a) admin PATCH that flips status to "approved",
/// (b) nightly cron `/api/cron/recompute-scores` that also re-scores all rows.
///
/// Cold start: with sampleCount < ~5 the row may not exist; fall back to
/// hardcoded. Drift is unbounded by design — current hardcoded anchors are
/// based on limited research data, so empirical observations should
/// dominate fast.
/// Per-KvK population distribution from uploaded DKP scans. The KEY data
/// structure for the ratio-based scoring system: an applicant's expected
/// LIFETIME stats are computed by summing the p50 of stats across the
/// KvKs they're estimated to have played (based on accountBornAt). Their
/// score derives from how their actual lifetime stats compare to that
/// expectation.
///
/// One row per KvK identifier. Single-KvK distributions of active fighters:
/// power (current at end of KvK), kp (during KvK), t5/deaths (during KvK),
/// acclaim (single-KvK valor earned), dkp (composite DKP for that KvK).
///
/// Bootstrap with hardcoded priors in lib/scoring.ts; once any
/// BenchmarkUpload exists for a kvkId the priors are blended out via
/// sample-weighted averaging.
model KvkBenchmark {
  /// "kvk1" | "kvk2" | "kvk3" | "kvk4" | "soc"
  kvkId       String   @id
  /// JSON: per-stat percentiles. Shape:
  /// { power:{p50,p80,p95,p99}, kp:{...}, t5:{...}, deaths:{...},
  ///   acclaim:{...}, dkp:{...} }
  stats       Json
  /// Total active-fighter samples summed across all uploads for this kvkId.
  sampleCount Int
  updatedAt   DateTime @updatedAt

  @@map("kvk_benchmarks")
}

/// Snapshot of all RoK kingdoms with their seed-group assignment from
/// HeroScrolls (heroscroll.com/rok/seeds). Lets admin cross-reference
/// an applicant's source kingdom against the broader population:
/// "applicant came from kingdom 3091 → Group B → mid-tier" at a glance.
///
/// Seed assignment mirrors HeroScrolls' algorithm:
///   ranks 1-24                 → "Imperium"  (Elite 24)
///   next quarter of remaining  → "A"         (Group A — strongest)
///   next quarter               → "B"
///   next quarter               → "C"
///   bottom quarter             → "D"
///
/// Refreshed by scripts/import-heroscroll-seeds.ts (one-shot scrape +
/// upsert). Re-run periodically to track kingdom drift between groups.
model KingdomSeed {
  /// In-game kingdom number (e.g. 4028, 3091).
  kingdomId           Int      @id
  /// "Imperium" | "A" | "B" | "C" | "D"
  seed                String
  /// Global rank from HeroScrolls (1 = strongest by composite rating).
  rank                Int
  /// Aggregate stats — sum across the kingdom's top 300 governors.
  totalPower          Float
  totalKillpoints     Float
  totalDeads          Float
  totalTroopPower     Float
  totalAcclaim        Float
  /// Player counts. ch25 = governors at city hall 25.
  playerCount         Int
  ch25Count           Int
  domainCount         Int
  inactivePlayerCount Int
  /// HeroScrolls scrape metadata.
  scrapedTimestamp    String   // "YYYY-MM-DD" (the day heroscroll's data ref's to)
  lastUpdated         BigInt   // unix ms — last time heroscroll refreshed this row
  importedAt          DateTime @default(now()) @updatedAt

  @@index([seed])
  @@index([rank])
  @@map("kingdom_seeds")
}

/// Audit trail of DKP-scan uploads that fed KvkBenchmark. Stores
/// per-upload aggregates only — NO raw rows. Lets admin remove a bad
/// upload (e.g. typo on kvkId, irrelevant kingdom) and rebuild benchmarks
/// without that contribution.
model BenchmarkUpload {
  id          String   @id @default(cuid())
  kvkId       String
  /// Free-form, e.g. "kingdom 3801 KvK4 export, Apr 2026".
  notes       String?
  rowCount    Int
  /// Same shape as KvkBenchmark.stats — but for THIS upload only.
  stats       Json
  uploadedAt  DateTime @default(now())

  @@index([kvkId, uploadedAt])
  @@map("benchmark_uploads")
}
