# Postgres connection string. For Neon free tier, use the pooled URL.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Bearer token required for all admin (write) routes. Generate with `openssl rand -hex 32`.
ADMIN_TOKEN="change-me-in-production"

# Comma-separated origins allowed by CORS. List your landing + admin URLs.
# Leave empty in dev to allow any origin.
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"
