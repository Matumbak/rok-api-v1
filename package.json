{
  "name": "rok-api",
  "version": "1.0.0",
  "description": "API for the 4028 Huns landing + admin panel (Next.js Route Handlers on Vercel)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "prisma generate && next build",
    "start": "next start -p 4000",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "deploy:sync": "prisma db push --skip-generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "dotenv": "^17.4.2",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "prisma": "^5.22.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
